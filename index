<script>
// ─── PARTICLES ───
(function(){
  const container = document.getElementById('particles');
  for(let i=0; i<30; i++){
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.cssText = `
      left:${Math.random()*100}%;
      width:${Math.random()*2+1}px;
      height:${Math.random()*2+1}px;
      animation-duration:${8+Math.random()*15}s;
      animation-delay:${Math.random()*10}s;
      opacity:${Math.random()*0.5};
    `;
    container.appendChild(p);
  }
})();

// ─── HAMBURGER ───
const hamburger = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobileMenu');
hamburger.addEventListener('click', () => mobileMenu.classList.toggle('open'));
function closeMobileMenu(){ mobileMenu.classList.remove('open'); }

// ─── COPY FUNCTIONS ───
function copyToClipboard(text, el){
  navigator.clipboard.writeText(text).then(()=>{
    const orig = el.querySelector('span:last-child').textContent;
    el.querySelector('span:last-child').textContent = '✓ کپی شد!';
    setTimeout(()=>{ el.querySelector('span:last-child').textContent = orig; }, 2000);
  });
}
function copyAddress(){
  const addr = document.getElementById('serverAddr').textContent;
  navigator.clipboard.writeText(addr).then(()=>{
    const btn = document.querySelector('.copy-btn');
    btn.textContent = '✓ کپی شد!';
    setTimeout(()=>{ btn.textContent = '📋 کپی آدرس'; }, 2000);
  });
}

// ─── TABS (upgrade/fund) ───
function switchTab(section, tab){
  const panels = document.querySelectorAll(`#${section} .tab-panel`);
  const btns = document.querySelectorAll(`#${section} .tab-btn`);
  panels.forEach(p=>p.classList.remove('active'));
  btns.forEach(b=>b.classList.remove('active'));
  document.getElementById(`${section}-${tab}`).classList.add('active');
  event.target.classList.add('active');
}

// ─── RULES TABS ───
function switchRulesTab(tab){
  document.getElementById('rules-const').style.display = tab==='const'?'block':'none';
  document.getElementById('rules-combat').style.display = tab==='combat'?'block':'none';
  document.querySelectorAll('.rules-tab-btn').forEach((b,i)=>{
    b.classList.toggle('active', (i===0&&tab==='const')||(i===1&&tab==='combat'));
  });
}

// ─── ACCORDION ───
function toggleAccordion(header){
  const body = header.nextElementSibling;
  const isOpen = header.classList.contains('open');
  header.classList.toggle('open', !isOpen);
  body.classList.toggle('open', !isOpen);
}

// ─── SCROLL REVEAL ───
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('visible');
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
revealEls.forEach(el=>observer.observe(el));
</script>

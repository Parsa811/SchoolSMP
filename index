<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>School SMP IV — پادشاهی مدرسه</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #c9a84c;
    --gold-light: #f0d080;
    --gold-dark: #8b6914;
    --crimson: #8b0000;
    --crimson-light: #c0392b;
    --emerald: #1a7a4a;
    --emerald-light: #27ae60;
    --bg-deep: #080604;
    --bg-dark: #0f0b07;
    --bg-card: #161008;
    --bg-card2: #1c1409;
    --text-main: #e8d5a3;
    --text-dim: #a08050;
    --border-gold: rgba(201,168,76,0.35);
    --border-gold-bright: rgba(201,168,76,0.7);
    --shadow-gold: 0 0 30px rgba(201,168,76,0.15);
    --shadow-gold-intense: 0 0 60px rgba(201,168,76,0.3);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Tahoma', 'Arial', sans-serif;
    background: var(--bg-deep);
    color: var(--text-main);
    direction: rtl;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ─── NOISE TEXTURE OVERLAY ─── */
  body::before {
    content:'';
    position:fixed; inset:0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events:none;
    z-index:0;
    opacity:.4;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width:6px; }
  ::-webkit-scrollbar-track { background:#0a0806; }
  ::-webkit-scrollbar-thumb { background: var(--gold-dark); border-radius:3px; }

  /* ─── NAV ─── */
  nav {
    position: fixed; top:0; left:0; right:0; z-index:1000;
    background: linear-gradient(180deg, rgba(8,6,4,0.98) 0%, rgba(8,6,4,0.85) 100%);
    border-bottom: 1px solid var(--border-gold);
    backdrop-filter: blur(12px);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .nav-brand {
    font-family: 'Cinzel Decorative', serif;
    color: var(--gold);
    font-size: 1rem;
    text-shadow: 0 0 20px rgba(201,168,76,0.5);
    letter-spacing: 2px;
  }
  .nav-links {
    display: flex;
    gap: 0.3rem;
    list-style: none;
    flex-direction: row-reverse;
  }
  .nav-links a {
    color: var(--text-dim);
    text-decoration: none;
    font-size: 0.8rem;
    padding: 6px 12px;
    border: 1px solid transparent;
    border-radius: 3px;
    transition: all 0.3s;
    white-space: nowrap;
  }
  .nav-links a:hover {
    color: var(--gold);
    border-color: var(--border-gold);
    background: rgba(201,168,76,0.05);
  }

  /* ─── HERO ─── */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 64px;
  }

  .hero-bg {
    position: absolute; inset:0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%, rgba(139,105,20,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 50% 40% at 20% 80%, rgba(139,0,0,0.1) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 20%, rgba(26,122,74,0.08) 0%, transparent 60%),
      linear-gradient(180deg, #080604 0%, #0d0905 50%, #080604 100%);
  }

  /* Animated particles */
  .particles {
    position:absolute; inset:0;
    pointer-events:none;
  }
  .particle {
    position:absolute;
    width:2px; height:2px;
    background: var(--gold);
    border-radius:50%;
    animation: float-up linear infinite;
    opacity:0;
  }
  @keyframes float-up {
    0% { opacity:0; transform: translateY(100vh) scale(0); }
    10% { opacity:1; }
    90% { opacity:0.3; }
    100% { opacity:0; transform: translateY(-20vh) scale(1.5); }
  }

  .hero-content {
    position: relative; z-index:2;
    text-align: center;
    padding: 2rem;
    max-width: 900px;
    animation: hero-reveal 1.2s ease-out forwards;
  }
  @keyframes hero-reveal {
    from { opacity:0; transform: translateY(40px); }
    to { opacity:1; transform: translateY(0); }
  }

  .hero-flag {
    width: 320px;
    max-width: 85vw;
    border: 3px solid var(--gold);
    box-shadow: 0 0 50px rgba(201,168,76,0.3), 0 0 100px rgba(201,168,76,0.1);
    border-radius: 4px;
    margin-bottom: 2.5rem;
    animation: flag-glow 3s ease-in-out infinite alternate;
  }
  @keyframes flag-glow {
    from { box-shadow: 0 0 50px rgba(201,168,76,0.3), 0 0 100px rgba(201,168,76,0.1); }
    to { box-shadow: 0 0 70px rgba(201,168,76,0.5), 0 0 130px rgba(201,168,76,0.2); }
  }

  .hero-subtitle-top {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    letter-spacing: 5px;
    color: var(--gold-dark);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .hero-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(2.2rem, 5vw, 4rem);
    color: var(--gold);
    text-shadow: 0 0 40px rgba(201,168,76,0.6), 0 4px 20px rgba(0,0,0,0.8);
    line-height: 1.2;
    margin-bottom: 1.5rem;
    animation: title-pulse 4s ease-in-out infinite alternate;
  }
  @keyframes title-pulse {
    from { text-shadow: 0 0 40px rgba(201,168,76,0.6), 0 4px 20px rgba(0,0,0,0.8); }
    to { text-shadow: 0 0 70px rgba(201,168,76,0.9), 0 4px 30px rgba(0,0,0,0.9); }
  }
  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 1.5rem auto;
    max-width: 500px;
  }
  .hero-divider-line {
    flex:1;
    height:1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .hero-divider span { color: var(--gold); font-size: 1.2rem; }
  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-dim);
    line-height: 2;
    max-width: 600px;
    margin: 0 auto 2.5rem;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    background: linear-gradient(135deg, var(--gold-dark), var(--gold), var(--gold-dark));
    background-size: 200% 200%;
    color: #0a0806;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 40px;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    text-decoration: none;
    animation: btn-shimmer 3s ease infinite;
    box-shadow: 0 0 30px rgba(201,168,76,0.4);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .hero-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 50px rgba(201,168,76,0.6);
  }
  @keyframes btn-shimmer {
    0%,100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* ─── SECTION BASE ─── */
  section {
    position: relative;
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-full { max-width: 100%; padding-left: 0; padding-right: 0; }
  .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .section-label {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 6px;
    color: var(--gold-dark);
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.8rem;
  }
  .section-title {
    font-family: 'Cinzel Decorative', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.8rem);
    color: var(--gold);
    text-shadow: 0 0 30px rgba(201,168,76,0.4);
    margin-bottom: 1rem;
  }
  .ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 1.2rem auto;
  }
  .ornament-line {
    flex:1; max-width: 200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-gold-bright), transparent);
  }
  .ornament span { color: var(--gold); font-size: 1rem; }

  /* ─── SEPARATOR ─── */
  .sep {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-gold), transparent);
    margin: 0;
  }

  /* ─── CARD BASE ─── */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: 6px;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .card::before {
    content:'';
    position:absolute; top:0; left:0; right:0;
    height:2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 40px rgba(201,168,76,0.15);
  }

  /* ─── SECTION 1: SHOP ─── */
  #shop { }
  .shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .shop-item {
    background: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: 6px;
    padding: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
  }
  .shop-item::after {
    content:'';
    position:absolute; inset:0;
    background: linear-gradient(135deg, rgba(201,168,76,0.03) 0%, transparent 60%);
    pointer-events:none;
  }
  .shop-item:hover {
    border-color: var(--gold);
    background: #1e1508;
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(201,168,76,0.15);
  }
  .shop-icon {
    font-size: 2rem;
    flex-shrink: 0;
    filter: drop-shadow(0 0 8px rgba(201,168,76,0.4));
  }
  .shop-info { flex:1; }
  .shop-name {
    font-size: 1rem;
    color: var(--gold-light);
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .shop-price {
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  .price-tag {
    display: inline-block;
    background: linear-gradient(135deg, rgba(139,0,0,0.3), rgba(201,168,76,0.15));
    border: 1px solid rgba(201,168,76,0.3);
    padding: 2px 10px;
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--gold);
    margin-top: 0.4rem;
  }
  .price-tag.diamond {
    background: linear-gradient(135deg, rgba(0,50,100,0.3), rgba(0,180,220,0.1));
    border-color: rgba(0,180,220,0.4);
    color: #7de8ff;
  }
  .shop-header-banner {
    text-align: center;
    background: linear-gradient(135deg, rgba(139,0,0,0.2), rgba(201,168,76,0.08), rgba(139,0,0,0.2));
    border: 1px solid var(--border-gold);
    border-radius: 6px;
    padding: 2rem;
    margin-bottom: 3rem;
  }
  .shop-header-banner h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    color: var(--gold);
    text-shadow: 0 0 20px rgba(201,168,76,0.5);
  }

  /* ─── SECTION 2: LANDS ─── */
  #lands { }
  .lands-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border-gold);
    border-radius: 8px;
  }
  .lands-table {
    width: 100%;
    border-collapse: collapse;
  }
  .lands-table thead tr {
    background: linear-gradient(90deg, rgba(139,0,0,0.4), rgba(201,168,76,0.15), rgba(139,0,0,0.4));
  }
  .lands-table th {
    padding: 1.2rem 1.5rem;
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    letter-spacing: 2px;
    color: var(--gold);
    text-align: right;
    border-bottom: 1px solid var(--border-gold);
    white-space: nowrap;
  }
  .lands-table td {
    padding: 1.1rem 1.5rem;
    font-size: 0.92rem;
    color: var(--text-main);
    border-bottom: 1px solid rgba(201,168,76,0.1);
    text-align: right;
  }
  .lands-table tbody tr {
    background: var(--bg-card);
    transition: background 0.2s;
  }
  .lands-table tbody tr:hover { background: #1c1408; }
  .lands-table tbody tr:last-child td { border-bottom: none; }
  .status-badge {
    display: inline-block;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .status-active { background: rgba(26,122,74,0.25); border:1px solid rgba(39,174,96,0.4); color: #5dd98e; }
  .status-pending { background: rgba(201,168,76,0.15); border:1px solid rgba(201,168,76,0.4); color: var(--gold); }
  .status-empty { background: rgba(100,100,100,0.15); border:1px solid rgba(150,150,150,0.3); color: #888; }
  .username-tag {
    font-family: 'Courier New', monospace;
    font-size: 0.82rem;
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.25);
    padding: 2px 8px;
    border-radius: 3px;
    color: var(--gold-light);
    white-space: nowrap;
  }

  /* ─── RANKS SECTION ─── */
  .ranks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .rank-card {
    background: var(--bg-card);
    border-radius: 8px;
    padding: 2.5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: all 0.35s;
  }
  .rank-card::before {
    content:'';
    position:absolute; inset:0;
    background: radial-gradient(ellipse at 50% 0%, var(--rank-glow,rgba(201,168,76,0.1)) 0%, transparent 65%);
    pointer-events:none;
  }
  .rank-card:hover { transform: translateY(-6px); box-shadow: 0 16px 50px var(--rank-glow,rgba(201,168,76,0.18)); }
  .rank-king { --rank-glow: rgba(201,168,76,0.18); border: 2px solid var(--gold); }
  .rank-hand { --rank-glow: rgba(180,30,30,0.2); border: 2px solid rgba(180,30,30,0.7); }
  .rank-judge { --rank-glow: rgba(70,130,180,0.2); border: 2px solid rgba(70,130,180,0.6); }
  .rank-badge {
    font-size: 3rem;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 12px var(--rank-glow,rgba(201,168,76,0.5)));
    animation: seal-pulse 3s ease-in-out infinite alternate;
  }
  .rank-title {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 4px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .rank-name {
    font-family: 'Cinzel Decorative', serif;
    font-size: 1.4rem;
    color: var(--gold);
    margin-bottom: 0.5rem;
    text-shadow: 0 0 20px rgba(201,168,76,0.4);
  }
  .rank-king .rank-name { color: var(--gold); }
  .rank-hand .rank-name { color: #e05555; text-shadow: 0 0 20px rgba(224,85,85,0.4); }
  .rank-judge .rank-name { color: #6ab4e8; text-shadow: 0 0 20px rgba(106,180,232,0.4); }
  .rank-role {
    display: inline-block;
    margin-top: 0.8rem;
    padding: 4px 16px;
    border-radius: 20px;
    font-size: 0.82rem;
    font-family: 'Cinzel', serif;
    letter-spacing: 1px;
  }
  .rank-king .rank-role { background: rgba(201,168,76,0.12); border:1px solid rgba(201,168,76,0.4); color:var(--gold); }
  .rank-hand .rank-role { background: rgba(180,30,30,0.12); border:1px solid rgba(180,30,30,0.5); color:#e05555; }
  .rank-judge .rank-role { background: rgba(70,130,180,0.12); border:1px solid rgba(70,130,180,0.5); color:#6ab4e8; }
  .rank-divider {
    width:40px; height:1px;
    background: linear-gradient(90deg,transparent,var(--gold),transparent);
    margin: 1rem auto;
  }

  .placeholder-note {
    background: rgba(201,168,76,0.05);
    border: 1px dashed rgba(201,168,76,0.3);
    border-radius: 6px;
    padding: 1rem 1.5rem;
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    text-align: center;
  }

  /* ─── SECTION 3 & 7: UPGRADE ─── */
  #upgrade, #fund { }
  .upgrade-tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border-gold);
    padding-bottom: 0;
    flex-wrap: wrap;
    justify-content: center;
  }
  .tab-btn {
    background: transparent;
    border: 1px solid var(--border-gold);
    border-bottom: none;
    color: var(--text-dim);
    padding: 10px 24px;
    cursor: pointer;
    font-size: 0.9rem;
    border-radius: 4px 4px 0 0;
    transition: all 0.3s;
    position: relative;
    bottom: -1px;
  }
  .tab-btn.active {
    background: var(--bg-card);
    color: var(--gold);
    border-color: var(--gold);
    border-bottom: 1px solid var(--bg-card);
  }
  .tab-btn:hover:not(.active) {
    color: var(--gold-light);
    background: rgba(201,168,76,0.05);
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .points-system {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .point-item {
    background: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: 6px;
    padding: 1.2rem;
    text-align: center;
    transition: all 0.3s;
  }
  .point-item:hover { transform: translateY(-3px); box-shadow: 0 8px 25px rgba(201,168,76,0.15); }
  .point-icon { font-size: 2rem; margin-bottom: 0.5rem; }
  .point-name { font-size: 0.85rem; color: var(--text-dim); margin-bottom: 0.4rem; }
  .point-val { font-family: 'Cinzel', serif; font-size: 1.1rem; color: var(--gold); font-weight: 700; }

  .tier-section { margin-bottom: 2.5rem; }
  .tier-title {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.2rem;
    padding: 0.8rem 1.5rem;
    border-radius: 4px;
  }
  .tier-title span { font-family: 'Cinzel', serif; font-size: 1rem; letter-spacing:2px; }

  .tier-green .tier-title { background: rgba(39,174,96,0.1); border-right: 3px solid #27ae60; }
  .tier-yellow .tier-title { background: rgba(241,196,15,0.1); border-right: 3px solid #f1c40f; }
  .tier-orange .tier-title { background: rgba(230,126,34,0.1); border-right: 3px solid #e67e22; }
  .tier-red .tier-title { background: rgba(231,76,60,0.1); border-right: 3px solid #e74c3c; }
  .tier-purple .tier-title { background: rgba(155,89,182,0.1); border-right: 3px solid #9b59b6; }
  .tier-black .tier-title { background: rgba(80,80,80,0.1); border-right: 3px solid #888; }

  .level-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.8rem;
  }
  .level-card {
    background: var(--bg-card);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 5px;
    padding: 1rem;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .level-card:hover {
    border-color: var(--border-gold);
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(201,168,76,0.12);
  }
  .level-num {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    color: var(--text-dim);
    margin-bottom: 0.3rem;
  }
  .level-emoji { font-size: 1.5rem; margin-bottom: 0.3rem; }
  .level-blocks {
    font-size: 0.9rem;
    color: var(--gold-light);
    margin-bottom: 0.3rem;
  }
  .level-pts {
    font-family: 'Cinzel', serif;
    font-size: 0.85rem;
    color: var(--gold);
  }

  /* Heart system */
  .heart-timeline { display: flex; flex-direction: column; gap: 0; }
  .heart-step {
    display: flex;
    align-items: stretch;
    gap: 1.5rem;
    position: relative;
  }
  .heart-step-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 40px;
    flex-shrink: 0;
  }
  .heart-dot {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
    z-index:1;
  }
